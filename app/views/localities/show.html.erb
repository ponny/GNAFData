<% content_for :title, "#{@locality.locality_name} - Addresses" %>

<div class="container mx-auto px-4 py-8">
  <div class="mb-8">
    <nav class="flex items-center space-x-2 text-sm text-gray-500 mb-4">
      <%= link_to "Home", root_path, class: "hover:text-blue-600" %>
      <span>/</span>
      <%= link_to "Localities", localities_path, class: "hover:text-blue-600" %>
      <span>/</span>
      <span class="text-gray-900"><%= @locality.locality_name %></span>
    </nav>
    
    <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= @locality.locality_name %></h1>
    <div class="flex items-center space-x-4 text-gray-600">
      <span><strong>State:</strong> <%= @locality.state.state_name %></span>
      <span><strong>Postcode:</strong> <%= @locality.postcode %></span>
      <span><strong>Total Addresses:</strong> <%= number_with_delimiter(@addresses.count) %></span>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-md p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-semibold text-gray-900">All Addresses</h2>
      <div class="space-x-2">
        <button onclick="selectAllAddresses()" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors text-sm">
          Select All
        </button>
        <%= link_to "Download CSV", download_csv_locality_path(@locality, format: :csv), 
                   class: "bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors text-sm" %>
      </div>
    </div>
    
    <p class="text-gray-600 text-sm mb-4">
      Click "Select All" to select all addresses for easy copying. Each address is on a separate line.
    </p>
    
    <textarea id="addressList" 
              readonly
              class="w-full h-96 p-4 border border-gray-300 rounded-lg font-mono text-sm resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              placeholder="Loading addresses..."><%= @address_list %></textarea>
    
    <div class="mt-4 text-sm text-gray-500">
      <strong><%= number_with_delimiter(@addresses.count) %></strong> addresses total
    </div>
  </div>
</div>

<script>
function selectAllAddresses() {
  const textarea = document.getElementById('addressList');
  textarea.select();
  textarea.setSelectionRange(0, 99999); // For mobile devices
  
  // Try to copy to clipboard
  try {
    document.execCommand('copy');
    // Show a brief success message
    const button = event.target;
    const originalText = button.textContent;
    button.textContent = 'Copied!';
    button.classList.remove('bg-blue-600', 'hover:bg-blue-700');
    button.classList.add('bg-green-600');
    
    setTimeout(() => {
      button.textContent = originalText;
      button.classList.remove('bg-green-600');
      button.classList.add('bg-blue-600', 'hover:bg-blue-700');
    }, 2000);
  } catch (err) {
    console.log('Copy failed, but text is selected');
  }
}
</script>

<% content_for :title, "GNAF Localities" %>

<div class="container mx-auto px-4 py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-4">Australian Localities</h1>
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-center">
        <div>
          <div class="text-2xl font-bold text-blue-600"><%= @total_localities %></div>
          <div class="text-sm text-gray-600">Total Localities</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-green-600"><%= number_with_delimiter(@total_addresses) %></div>
          <div class="text-sm text-gray-600">Total Addresses</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-purple-600"><%= @localities.map(&:address_count).sum %></div>
          <div class="text-sm text-gray-600">Addresses with Localities</div>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white shadow-sm rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-medium text-gray-900">Localities by State</h2>
      <p class="text-sm text-gray-600">Click "Download CSV" to export all addresses for a locality</p>
    </div>
    
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">State</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Locality</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Postcode</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Addresses</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% current_state = nil %>
          <% @localities.each do |locality| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <% if current_state != locality.state_name %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                    <%= locality.state_name %>
                  </span>
                  <% current_state = locality.state_name %>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900">
                  <% if locality.address_count > 0 %>
                    <%= link_to locality.locality_name, locality_path(locality), class: "text-blue-600 hover:text-blue-800 hover:underline" %>
                  <% else %>
                    <%= locality.locality_name %>
                  <% end %>
                </div>
                <div class="text-sm text-gray-500"><%= locality.locality_class_code %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= locality.postcode %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
                <span class="<%= locality.address_count > 0 ? 'text-green-600 font-medium' : 'text-gray-400' %>">
                  <%= number_with_delimiter(locality.address_count) %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                <% if locality.address_count > 0 %>
                  <%= link_to download_csv_locality_path(locality, format: :csv), 
                             class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    Download CSV
                  <% end %>
                <% else %>
                  <span class="text-gray-400 text-sm">No addresses</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
